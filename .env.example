# App
NODE_ENV=development
PORT=4000
API_VERSION=v1
CLIENT_URL=http://localhost:3000

# Database (Aiven PostgreSQL — paste the service URI from the Aiven console)
# Aiven requires SSL; keep the ?sslmode=require suffix on the connection string.
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_key
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/login/google/callback

# Cloudinary (file storage — documents, avatars, logos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=flowdesk

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_STARTER_PRICE_ID=price_
STRIPE_GROWTH_PRICE_ID=price_
STRIPE_BUSINESS_PRICE_ID=price_

# SendGrid
SENDGRID_API_KEY=SG.
SENDGRID_FROM_EMAIL=no-reply@flowdesk.app
SENDGRID_FROM_NAME=FlowDesk

# Firebase (FCM for Flutter push)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Security
BCRYPT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Public holidays API (optional)
NAGER_API_BASE_URL=https://date.nager.at/api/v3
