// FlowDesk — Prisma schema
// Multi-tenant HR & Payroll SaaS. Every tenant-scoped model carries organizationId.
// Foundation (tenancy + auth) was seeded first; the full domain (org structure,
// employees, recruitment, onboarding, attendance, leave, payroll, performance,
// assets, notifications, audit, billing) is modeled below.
// DB: PostgreSQL (Aiven). Connection string comes from DATABASE_URL (see .env),
// loaded via prisma.config.ts.
//
// Convention notes:
//   * Structural foreign keys are modeled as real Prisma relations.
//   * Actor / audit pointers (createdBy, approvedBy, uploadedBy, …) are stored as
//     bare `String? @db.Uuid` scalars referencing users(id) — intentionally NOT
//     relations, to keep the User model free of dozens of back-references.
//   * Status / type columns are modeled as enums for type safety.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy & Auth (foundation)
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id                   String              @id @default(uuid()) @db.Uuid
  name                 String
  slug                 String              @unique
  industry             String?
  size                 String?
  country              String?
  timezone             String?             @default("UTC")
  currency             String?             @default("USD")
  logoUrl              String?             @map("logo_url")
  website              String?
  fiscalYearStart      Int                 @default(1) @map("fiscal_year_start")
  plan                 Plan                @default(STARTER)
  stripeCustomerId     String?             @map("stripe_customer_id")
  stripeSubscriptionId String?             @map("stripe_subscription_id")
  subscriptionStatus   SubscriptionStatus  @default(TRIALING) @map("subscription_status")
  trialEndsAt          DateTime?           @map("trial_ends_at")
  seatCount            Int                 @default(25) @map("seat_count")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")

  // Auth & tenancy
  users       User[]
  invitations Invitation[]

  // Org structure
  locations       Location[]
  departments     Department[]
  workSchedules   WorkSchedule[]
  publicHolidays  PublicHoliday[]

  // Employees
  employees Employee[]

  // Recruitment
  jobPostings    JobPosting[]
  pipelineStages PipelineStage[]

  // Onboarding
  onboardingTemplates OnboardingTemplate[]

  // Attendance
  shiftTemplates    ShiftTemplate[]
  shiftSchedules    ShiftSchedule[]
  attendanceEntries AttendanceEntry[]
  timesheets        Timesheet[]

  // Leave
  leaveTypes    LeaveType[]
  leavePolicies LeavePolicy[]
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  // Payroll
  payGroups      PayGroup[]
  payRuns        PayRun[]
  payslips       Payslip[]
  deductionTypes DeductionType[]
  taxSettings    TaxSettings?

  // Performance
  performanceCycles  PerformanceCycle[]
  goals              Goal[]
  continuousFeedback ContinuousFeedback[]

  // Assets
  assets        Asset[]
  assetRequests AssetRequest[]

  // Notifications & announcements
  notifications Notification[]
  announcements Announcement[]

  // Audit & billing
  auditLogs       AuditLog[]
  billingInvoices BillingInvoice[]

  @@map("organizations")
}

model User {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  passwordHash   String?       @map("password_hash")
  fullName       String        @map("full_name")
  role           Role          @default(EMPLOYEE)
  emailVerified  Boolean       @default(false) @map("email_verified")
  avatarUrl      String?       @map("avatar_url")
  isActive       Boolean       @default(true) @map("is_active")
  twoFaEnabled   Boolean       @default(false) @map("two_fa_enabled")
  twoFaSecret    String?       @map("two_fa_secret")
  lastLoginAt    DateTime?     @map("last_login_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sentInvitations         Invitation[]             @relation("InvitedBy")

  // Domain links
  employee                Employee?
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  announcementReads       AnnouncementRead[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth tokens & sessions
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           Role             @default(EMPLOYEE)
  departmentId   String?          @map("department_id") @db.Uuid
  tokenHash      String           @unique @map("token_hash")
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  invitedById    String?          @map("invited_by") @db.Uuid
  invitedBy      User?            @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([organizationId, status])
  @@map("invitations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Organization structure
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  city           String?
  country        String?
  timezone       String?
  isRemote       Boolean      @default(false) @map("is_remote")
  createdAt      DateTime     @default(now()) @map("created_at")

  employees      Employee[]
  jobPostings    JobPosting[]
  publicHolidays PublicHoliday[]
  assets         Asset[]

  @@index([organizationId])
  @@map("locations")
}

model Department {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  parentDepartmentId String?      @map("parent_department_id") @db.Uuid
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments   Department[] @relation("DepartmentHierarchy")
  // Points at the heading employee; kept as a scalar to avoid a second
  // Department<->Employee relation cycle.
  headId             String?      @map("head_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  employees   Employee[]
  jobPostings JobPosting[]

  @@index([organizationId])
  @@map("departments")
}

model WorkSchedule {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @map("organization_id") @db.Uuid
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                     String
  workDays                 Int[]        @default([1, 2, 3, 4, 5]) @map("work_days")
  dailyHours               Decimal      @default(8) @map("daily_hours") @db.Decimal(4, 2)
  overtimeThresholdDaily   Decimal?     @default(8) @map("overtime_threshold_daily") @db.Decimal(4, 2)
  overtimeThresholdWeekly  Decimal?     @default(40) @map("overtime_threshold_weekly") @db.Decimal(4, 2)
  isDefault                Boolean      @default(false) @map("is_default")
  createdAt                DateTime     @default(now()) @map("created_at")

  employees Employee[]

  @@index([organizationId])
  @@map("work_schedules")
}

model PublicHoliday {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String?      @map("location_id") @db.Uuid
  location       Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  name           String
  date           DateTime     @db.Date
  isCustom       Boolean      @default(false) @map("is_custom")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, date])
  @@map("public_holidays")
}

// ─────────────────────────────────────────────────────────────────────────────
// Employees
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?      @unique @map("user_id") @db.Uuid
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeNumber String?      @map("employee_number")

  // Personal
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  personalEmail    String?  @map("personal_email")
  workEmail        String   @map("work_email")
  phone            String?
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  gender           Gender?
  nationality      String?
  address          Json?
  emergencyContact Json?     @map("emergency_contact")
  avatarUrl        String?   @map("avatar_url")

  // Job
  jobTitle         String?         @map("job_title")
  departmentId     String?         @map("department_id") @db.Uuid
  department       Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  locationId       String?         @map("location_id") @db.Uuid
  location         Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  managerId        String?         @map("manager_id") @db.Uuid
  manager          Employee?       @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports    Employee[]      @relation("EmployeeManager")
  employmentType   EmploymentType  @default(FULL_TIME) @map("employment_type")
  workScheduleId   String?         @map("work_schedule_id") @db.Uuid
  workSchedule     WorkSchedule?   @relation(fields: [workScheduleId], references: [id], onDelete: SetNull)
  startDate        DateTime        @map("start_date") @db.Date
  probationEndDate DateTime?       @map("probation_end_date") @db.Date
  terminationDate  DateTime?       @map("termination_date") @db.Date
  terminationReason String?        @map("termination_reason")
  status           EmployeeStatus  @default(ACTIVE)

  // Compensation
  salaryType  SalaryType @default(SALARIED) @map("salary_type")
  baseSalary  Decimal?   @map("base_salary") @db.Decimal(14, 2)
  hourlyRate  Decimal?   @map("hourly_rate") @db.Decimal(10, 2)
  currency    String?    @default("USD")
  payGroupId  String?    @map("pay_group_id") @db.Uuid
  payGroup    PayGroup?  @relation(fields: [payGroupId], references: [id], onDelete: SetNull)

  // Banking
  bankName            String?       @map("bank_name")
  bankAccountNumber   String?       @map("bank_account_number")
  bankRoutingNumber   String?       @map("bank_routing_number")
  paymentMethod       PaymentMethod @default(DIRECT_DEPOSIT) @map("payment_method")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  documents            EmployeeDocument[]
  roleChanges          RoleChange[]
  onboardingChecklists OnboardingChecklist[]
  shiftSchedules       ShiftSchedule[]
  attendanceEntries    AttendanceEntry[]
  timesheets           Timesheet[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  payRunLines          PayRunLine[]
  payRunAdjustments    PayRunAdjustment[]
  payslips             Payslip[]
  performanceReviews   PerformanceReview[]
  goals                Goal[]
  feedbackGiven        ContinuousFeedback[]  @relation("FeedbackGiven")
  feedbackReceived     ContinuousFeedback[]  @relation("FeedbackReceived")
  assetAssignments     AssetAssignment[]
  assetRequests        AssetRequest[]
  interviewPanels      InterviewPanelist[]
  interviewFeedbacks   InterviewFeedback[]

  @@unique([organizationId, workEmail])
  @@index([organizationId])
  @@index([departmentId])
  @@index([managerId])
  @@index([organizationId, status])
  @@map("employees")
}

model EmployeeDocument {
  id                   String    @id @default(uuid()) @db.Uuid
  employeeId           String    @map("employee_id") @db.Uuid
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name                 String
  type                 String?
  cloudinaryPublicId   String    @map("cloudinary_public_id")
  secureUrl            String?   @map("secure_url")
  fileSize             BigInt?   @map("file_size")
  mimeType             String?   @map("mime_type")
  expiryDate           DateTime? @map("expiry_date") @db.Date
  signedAt             DateTime? @map("signed_at")
  uploadedBy           String?   @map("uploaded_by") @db.Uuid // → users(id)
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([employeeId])
  @@map("employee_documents")
}

model RoleChange {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changedBy     String?   @map("changed_by") @db.Uuid // → users(id)
  field         String
  oldValue      String?   @map("old_value")
  newValue      String?   @map("new_value")
  effectiveDate DateTime? @map("effective_date") @db.Date
  reason        String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([employeeId])
  @@map("role_changes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Recruitment
// ─────────────────────────────────────────────────────────────────────────────

model JobPosting {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  departmentId    String?        @map("department_id") @db.Uuid
  department      Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  locationId      String?        @map("location_id") @db.Uuid
  location        Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)
  employmentType  EmploymentType? @map("employment_type")
  remoteType      RemoteType?    @map("remote_type")
  salaryMin       Decimal?       @map("salary_min") @db.Decimal(14, 2)
  salaryMax       Decimal?       @map("salary_max") @db.Decimal(14, 2)
  currency        String?
  description     String?
  requirements    String[]
  benefits        String[]
  status          JobStatus      @default(DRAFT)
  visibility      JobVisibility  @default(PUBLIC)
  hiringManagerId String?        @map("hiring_manager_id") @db.Uuid // → employees(id)
  recruiterId     String?        @map("recruiter_id") @db.Uuid // → employees(id)
  createdBy       String?        @map("created_by") @db.Uuid // → users(id)
  publishedAt     DateTime?      @map("published_at")
  closedAt        DateTime?      @map("closed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  applications Application[]

  @@index([organizationId, status])
  @@map("job_postings")
}

model PipelineStage {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  orderIndex     Int          @map("order_index")
  color          String?
  isDefault      Boolean      @default(false) @map("is_default")
  isFinal        Boolean      @default(false) @map("is_final")
  createdAt      DateTime     @default(now()) @map("created_at")

  applications Application[]

  @@index([organizationId])
  @@map("pipeline_stages")
}

model Application {
  id                    String            @id @default(uuid()) @db.Uuid
  jobPostingId          String            @map("job_posting_id") @db.Uuid
  jobPosting            JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  stageId               String?           @map("stage_id") @db.Uuid
  stage                 PipelineStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)
  candidateName         String            @map("candidate_name")
  candidateEmail        String            @map("candidate_email")
  candidatePhone        String?           @map("candidate_phone")
  cvCloudinaryPublicId  String?           @map("cv_cloudinary_public_id")
  coverLetter           String?           @map("cover_letter")
  source                String?
  status                ApplicationStatus @default(ACTIVE)
  rejectionReason       String?           @map("rejection_reason")
  appliedAt             DateTime          @default(now()) @map("applied_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  notes      ApplicationNote[]
  interviews Interview[]
  offers     Offer[]

  @@index([jobPostingId, stageId])
  @@map("applications")
}

model ApplicationNote {
  id            String      @id @default(uuid()) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String?     @map("author_id") @db.Uuid // → users(id)
  content       String
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([applicationId])
  @@map("application_notes")
}

model Interview {
  id              String           @id @default(uuid()) @db.Uuid
  applicationId   String           @map("application_id") @db.Uuid
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime         @map("scheduled_at")
  durationMinutes Int              @default(60) @map("duration_minutes")
  type            InterviewType    @default(VIDEO)
  meetingLink     String?          @map("meeting_link")
  location        String?
  status          InterviewStatus  @default(SCHEDULED)
  createdBy       String?          @map("created_by") @db.Uuid // → users(id)
  createdAt       DateTime         @default(now()) @map("created_at")

  panelists InterviewPanelist[]
  feedback  InterviewFeedback[]

  @@index([applicationId])
  @@map("interviews")
}

model InterviewPanelist {
  interviewId String    @map("interview_id") @db.Uuid
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  employeeId  String    @map("employee_id") @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([interviewId, employeeId])
  @@map("interview_panelists")
}

model InterviewFeedback {
  id             String                  @id @default(uuid()) @db.Uuid
  interviewId    String                  @map("interview_id") @db.Uuid
  interview      Interview               @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewerId  String?                 @map("interviewer_id") @db.Uuid
  interviewer    Employee?               @relation(fields: [interviewerId], references: [id], onDelete: SetNull)
  rating         Int?
  strengths      String?
  weaknesses     String?
  recommendation InterviewRecommendation?
  submittedAt    DateTime                @default(now()) @map("submitted_at")

  @@index([interviewId])
  @@map("interview_feedback")
}

model Offer {
  id                            String      @id @default(uuid()) @db.Uuid
  applicationId                 String      @map("application_id") @db.Uuid
  application                   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  salary                        Decimal     @db.Decimal(14, 2)
  currency                      String?
  startDate                     DateTime?   @map("start_date") @db.Date
  offerLetterCloudinaryPublicId String?     @map("offer_letter_cloudinary_public_id")
  status                        OfferStatus @default(DRAFT)
  sentAt                        DateTime?   @map("sent_at")
  signedAt                      DateTime?   @map("signed_at")
  expiresAt                     DateTime?   @map("expires_at")
  createdBy                     String?     @map("created_by") @db.Uuid // → users(id)
  createdAt                     DateTime    @default(now()) @map("created_at")

  @@index([applicationId])
  @@map("offers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Onboarding
// ─────────────────────────────────────────────────────────────────────────────

model OnboardingTemplate {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  createdBy      String?      @map("created_by") @db.Uuid // → users(id)
  createdAt      DateTime     @default(now()) @map("created_at")

  tasks      OnboardingTemplateTask[]
  checklists OnboardingChecklist[]

  @@index([organizationId])
  @@map("onboarding_templates")
}

model OnboardingTemplateTask {
  id           String             @id @default(uuid()) @db.Uuid
  templateId   String             @map("template_id") @db.Uuid
  template     OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  dueAfterDays Int                @default(1) @map("due_after_days")
  assignTo     OnboardingAssignee @default(EMPLOYEE) @map("assign_to")
  orderIndex   Int                @map("order_index")

  @@index([templateId])
  @@map("onboarding_template_tasks")
}

model OnboardingChecklist {
  id         String              @id @default(uuid()) @db.Uuid
  employeeId String              @map("employee_id") @db.Uuid
  employee   Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  templateId String?             @map("template_id") @db.Uuid
  template   OnboardingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  status     ChecklistStatus     @default(IN_PROGRESS)
  createdAt  DateTime            @default(now()) @map("created_at")

  tasks OnboardingTask[]

  @@index([employeeId])
  @@map("onboarding_checklists")
}

model OnboardingTask {
  id          String              @id @default(uuid()) @db.Uuid
  checklistId String              @map("checklist_id") @db.Uuid
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?           @map("due_date") @db.Date
  assignedTo  String?             @map("assigned_to") @db.Uuid // → users(id)
  assignTo    OnboardingAssignee  @default(EMPLOYEE) @map("assign_to")
  status      OnboardingTaskStatus @default(PENDING)
  completedAt DateTime?           @map("completed_at")
  note        String?
  orderIndex  Int                 @map("order_index")

  @@index([checklistId])
  @@map("onboarding_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Attendance
// ─────────────────────────────────────────────────────────────────────────────

model ShiftTemplate {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  startTime      DateTime     @map("start_time") @db.Time()
  endTime        DateTime     @map("end_time") @db.Time()
  breakMinutes   Int          @default(0) @map("break_minutes")
  color          String?
  createdAt      DateTime     @default(now()) @map("created_at")

  schedules ShiftSchedule[]

